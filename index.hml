  <section class="hero" id="home">
    <div class="hero-container">
      <div class="hero-content">
        <div class="tagline"><i class="fas fa-award"></i> SPE Nigeria Council Patent Recognition Program</div>
        <h1>Engineering the <span class="highlight">Niger Delta</span><br>Production Future</h1>
        <p class="subtitle">
          Petroleum Engineering Technologist. Inventor of 5 integrated production optimization technologies 
          for marginal fields. Bridging downhole hardware, surface gas-lift systems, AI-native artificial lift, 
          and autonomous reservoir intelligence.
        </p>
        <div class="hero-btns">
          <a href="#innovations" class="btn btn-primary"><i class="fas fa-rocket"></i> Explore Innovations</a>
          <a href="ND-Portfolio.pdf" class="btn btn-outline" download><i class="fas fa-file-pdf"></i> Download Portfolio</a>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <div class="stat-number">5</div>
            <div class="stat-label">Patent-Pending Innovations</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">3</div>
            <div class="stat-label">SPE Patent Applications</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Growth</div>
